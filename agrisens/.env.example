# ════════════════════════════════════
# AGRISENS – Variables d'environnement
# ════════════════════════════════════
# ⚠️  Copier ce fichier en .env et remplir les valeurs
# ⚠️  Ne jamais commiter .env dans Git

NODE_ENV=development

# ─────────────────────────────
# API
# ─────────────────────────────
API_PORT=3000
API_BASE_URL=http://localhost:3000

# ─────────────────────────────
# JWT
# ─────────────────────────────
JWT_SECRET=change_me_super_secret_jwt_key_256bits
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_super_secret_refresh_key
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────
# PostgreSQL
# ─────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=agrisens
POSTGRES_USER=agrisens_user
POSTGRES_PASSWORD=agrisens_pass
DATABASE_URL=postgresql://agrisens_user:agrisens_pass@postgres:5432/agrisens

# ─────────────────────────────
# InfluxDB
# ─────────────────────────────
INFLUX_HOST=http://influxdb
INFLUX_PORT=8086
INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=change_me_influx_admin_token
INFLUX_ORG=agrisens
INFLUX_BUCKET=agrisens_timeseries
INFLUX_BUCKET_AGG=agrisens_aggregates

# ─────────────────────────────
# MQTT
# ─────────────────────────────
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_WS_PORT=9001
MQTT_URL=mqtt://mosquitto:1883
MQTT_USERNAME=agrisens_broker
MQTT_PASSWORD=change_me_mqtt_pass
MQTT_CLIENT_ID=agrisens_api
MQTT_TOPIC_PREFIX=agrisens

# ─────────────────────────────
# Notifications
# ─────────────────────────────
# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="AgriSens <no-reply@agrisens.io>"

# SMS – Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_FROM=

# Push – Firebase
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ─────────────────────────────
# pgAdmin (dev only)
# ─────────────────────────────
PGADMIN_EMAIL=admin@agrisens.io
PGADMIN_PASSWORD=admin123

# ─────────────────────────────
# Rate limiting
# ─────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
